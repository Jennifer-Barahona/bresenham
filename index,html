


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Bresenham Visualizer</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 20px;
        }
        .controls {
            margin-bottom: 20px;
        }
        .main-layout {
            display: flex;
        }
        #tablaResultado {
            margin-left: 20px;
            border-collapse: collapse;
        }
        #tablaResultado th, #tablaResultado td {
            border: 1px solid #ddd;
            padding: 8px;
        }
        #tablaResultado th {
            background-color: #f2f2f2;
        }
</style>
</head>
<body>
    <div class="controls">
        X0: <input type="number" id="x0" value="2"> Y0: <input type="number" id="y0" value="2"> |
        X1: <input type="number" id="x1" value="15"> Y1: <input type="number" id="y1" value="10">
        <button onclick="ejecutar()">Dibujar</button>
    </div>
    <div class="main-layout">
        <canvas id="canvasBresenham" width="600" height="500"></canvas>
        <div id="tablaResultado"></div>
    </div>
</body>

<script src="script.js"></script>

</html>